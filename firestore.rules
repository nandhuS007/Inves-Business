rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
         request.auth.token.get('email', '') == "nandhanandha2426@gmail.com");
    }

    function isSeller() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'seller';
    }

    function isActive() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', 'blocked') == 'active';
    }

    function isDocOwner(docData) {
      return isAuthenticated() && request.auth.uid == docData.ownerId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 2. Listings Collection
    match /listings/{listingId} {
      allow read: if resource.data.status == 'approved' || 
                    (isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin()));
      
      // Only sellers/admins can create, must be active
      allow create: if (isSeller() || isAdmin()) && isActive();
      
      // Only owner/admin can update. Status change is admin only or seller can request 'under_review'
      allow update: if (isActive() && (resource.data.ownerId == request.auth.uid || isAdmin())) &&
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['analytics']) || 
                        isAdmin() || 
                        (resource.data.ownerId == request.auth.uid && request.resource.data.status == 'under_review'));
      
      allow delete: if isActive() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 3. Documents Collection
    match /documents/{docId} {
      allow read: if isAuthenticated() && (request.auth.uid == (resource.data.userId || "") || isAdmin() || 
                    (exists(/databases/$(database)/documents/listings/$(resource.data.listingId)) && 
                     get(/databases/$(database)/documents/listings/$(resource.data.listingId)).data.ownerId == request.auth.uid));
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && (request.auth.uid == (resource.data.userId || "") || isAdmin());
    }

    // 8. Orders Collection
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 4. Plans Collection
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Reviews Collection
    match /reviews/{reviewId} {
      allow read: if isAuthenticated() && 
                    (isAdmin() || 
                     (exists(/databases/$(database)/documents/listings/$(resource.data.listingId)) && 
                      get(/databases/$(database)/documents/listings/$(resource.data.listingId)).data.ownerId == request.auth.uid));
      allow write: if isAdmin();
    }

    // 6. Chats Collection
    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // 7. Favorites Collection
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // 9. Enquiries Collection
    match /enquiries/{enquiryId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || 
                    (exists(/databases/$(database)/documents/listings/$(resource.data.businessId)) && 
                     get(/databases/$(database)/documents/listings/$(resource.data.businessId)).data.ownerId == request.auth.uid));
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
