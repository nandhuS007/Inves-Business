// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - name: string
//   - email: string (required)
//   - phone: string
//   - role: string (required, ['buyer', 'vendor', 'admin'])
//   - subscription: map (optional)
//
// Collection: businesses
// Document ID: {businessId}
// Fields:
//   - title: string (required)
//   - category: string (required, ['Micro Business', 'Partnership Sale', 'Full Business', 'Investment'])
//   - price: number (required)
//   - location: string (required)
//   - description: string (required)
//   - revenue: number
//   - profit: number
//   - yearsOfOperation: number
//   - documents: list of strings
//   - images: list of strings
//   - status: string (required, ['under_review', 'approved', 'rejected'])
//   - isFeatured: bool
//   - ownerId: string (required)
//   - createdAt: timestamp
//
// Collection: enquiries
// Document ID: {enquiryId}
// Fields:
//   - userId: string (required)
//   - businessId: string (required)
//   - vendorId: string (required)
//   - message: string (required)
//   - createdAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.get('role', 'user') == 'admin' ||
         request.auth.token.get('email', '') == "nandhanandha2426@gmail.com");
    }
    
    function isVendor() {
      return isAuthenticated() && request.auth.token.role == 'vendor';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /public_profiles/{userId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(userId);
    }

    match /businesses/{businessId} {
      allow read: if resource.data.get('status', '') == 'approved' || 
                    (isAuthenticated() && (resource.data.get('ownerId', '') == request.auth.uid || isAdmin()));
      allow create: if isVendor() || isAdmin();
      allow update: if (isAuthenticated() && (resource.data.get('ownerId', '') == request.auth.uid || isAdmin())) ||
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
      allow delete: if (isAuthenticated() && (resource.data.get('ownerId', '') == request.auth.uid || isAdmin()));
    }

    match /enquiries/{enquiryId} {
      allow read: if isAuthenticated() && (resource.data.get('userId', '') == request.auth.uid || resource.data.get('vendorId', '') == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
